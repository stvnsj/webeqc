---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import { services } from "../data/services";
---

<BaseLayout
  title="Servicios | EQC Ltda."
  description="[Descripción breve de los servicios principales de EQC.]"
>
  <section class="page-section">
    <Container>
      <div class="page-intro">
        <p class="section-eyebrow">Servicios</p>
        <h1>Áreas de trabajo</h1>
        <p>
          [Texto introductorio general sobre el tipo de apoyo técnico o
          profesional que presta la empresa.]
        </p>
      </div>

      <div class="service-detail-list">
        {services.map((service) => (
          <article class="service-detail">
            <h2>{service.title}</h2>
            <p>{service.details}</p>

            <ul>
              {service.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>